rules_version = '2';
    service cloud.firestore {
      match /databases/{database}/documents {

        // ── HELPERS ────────────────────────────────────────────────────────────────

        function isAuth() {
          return request.auth != null;
        }

        function uid() {
          return request.auth.uid;
        }

        // Obtiene el doc del usuario de forma segura (devuelve null si no existe)
        function getUserData() {
          return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
        }

        function perteneceAEmpresa(empresaId) {
          return isAuth()
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && getUserData().empresa_id == empresaId;
        }

        function getRol() {
          return isAuth()
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            ? getUserData().rol
            : '';
        }

        function esPropietario(empresaId) {
          return perteneceAEmpresa(empresaId) && getRol() == 'propietario';
        }

        function esAdminOPropietario(empresaId) {
          return perteneceAEmpresa(empresaId)
            && (getRol() == 'admin' || getRol() == 'propietario');
        }

        function esStaffOSuperior(empresaId) {
          return perteneceAEmpresa(empresaId)
            && (getRol() == 'staff' || getRol() == 'admin' || getRol() == 'propietario');
        }

        // Admin de la plataforma (FluxTech) — puede leer datos globales
        function esPlataformaAdmin() {
          return isAuth()
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && getUserData().es_plataforma_admin == true;
        }

        // ── MÓDULOS DE STAFF ───────────────────────────────────────────────────────
        // El admin configura qué módulos puede ver cada staff en:
        //   usuarios/{staffUid}/modulos_permitidos  →  ['reservas','clientes',...]
        // Si no tiene modulos_permitidos, usa los defaults del rol staff.

        function modulosStaff() {
          return getUserData().get('modulos_permitidos',
            ['reservas', 'citas', 'clientes', 'valoraciones']);
        }

        // Staff tiene acceso a un módulo concreto (por config del admin o por defecto)
        function staffTieneModulo(empresaId, moduloId) {
          return perteneceAEmpresa(empresaId)
            && getRol() == 'staff'
            && modulosStaff().hasAny([moduloId]);
        }

        // Cualquier usuario con acceso al módulo (admin/propietario siempre sí,
        // staff solo si el admin le dio ese módulo)
        function puedeVerModulo(empresaId, moduloId) {
          return esAdminOPropietario(empresaId)
            || staffTieneModulo(empresaId, moduloId);
        }

        // ── USUARIOS ───────────────────────────────────────────────────────────────

        match /usuarios/{userId} {
          // El propio usuario puede leer/escribir su doc
          // Admin/propietario puede leer/escribir docs de su empresa
          allow read, write: if isAuth()
          allow read: if isAuth()
          allow read: if isAuth()
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
          // Cualquier auth puede crear su propio doc (registro normal)
            && (getUserData().rol == 'admin' || getUserData().rol == 'propietario');
          // Admin/propietario puede crear fichas de empleados manuales (sin cuenta Auth)
          allow create: if isAuth()
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && request.resource.data.empresa_id == getUserData().empresa_id
            && (getUserData().rol == 'admin' || getUserData().rol == 'propietario');
          // Cualquier auth puede crear su propio doc (registro)
          allow create: if isAuth() && uid() == userId;

          // EMBARGOS — subcolección de cada usuario
          // [FIX-9] Lectura/escritura: el propio usuario O admin/propietario de su empresa
          match /embargos/{embargoId} {
            allow read, write: if isAuth() && uid() == userId;
            allow read, write: if isAuth()
              && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
              && exists(/databases/$(database)/documents/usuarios/$(userId))
              && getUserData().empresa_id == get(/databases/$(database)/documents/usuarios/$(userId)).data.empresa_id
              && (getUserData().rol == 'admin' || getUserData().rol == 'propietario');
          }

          // Subcolecciones genéricas del usuario (bajas_laborales, historial_salarial, etc.)
          match /{subcollection}/{docId} {
            allow read, write: if isAuth() && uid() == userId;
            allow read, write: if isAuth()
              && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
              && exists(/databases/$(database)/documents/usuarios/$(userId))
              && getUserData().empresa_id == get(/databases/$(database)/documents/usuarios/$(userId)).data.empresa_id
              && (getUserData().rol == 'admin' || getUserData().rol == 'propietario');
          }
        }

        // ── NOTIFICACIONES IN-APP (colección raíz) ────────────────────────────
        // [FIX-8] notificaciones/{empresaId}/items/{itemId}
        // Lectura: cualquier miembro de la empresa
        // Escritura: solo Cloud Functions (Admin SDK) — el cliente solo lee y marca leídas
        match /notificaciones/{empresaId}/items/{itemId} {
          allow read: if perteneceAEmpresa(empresaId);
          allow update: if esAdminOPropietario(empresaId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['leida']);
          allow create, delete: if false; // Solo Admin SDK
        }

        // ── VACACIONES ─────────────────────────────────────────────────────────────
        match /vacaciones/{empresaId}/{document=**} {
          allow read, write: if esAdminOPropietario(empresaId);
        }

        // ── LOGIN_INTENTOS — [FIX-7] Solo accesible desde Admin SDK ────────────
        match /login_intentos/{email} {
          allow read, write: if false;
        }

        // ── INVITACIONES — [FIX-7] Solo accesible desde Admin SDK ──────────────
        match /invitaciones/{token} {
          allow read, write: if false;
        }

        // ── EMPRESAS ───────────────────────────────────────────────────────────────

        match /empresas/{empresaId} {
          // [FIX-1] Lectura SOLO para miembros de la empresa (antes: allow read: if true)
          allow read: if perteneceAEmpresa(empresaId);
          // [PLAT-ADMIN] El admin de la plataforma puede leer cualquier empresa
          // (necesario para el módulo de estadísticas globales)
          allow read: if esPlataformaAdmin();
          // [DEMO-FIX] Permite buscar empresa por correo aunque el usuario aún no tenga
          // documento en usuarios/{uid}. Necesario para la cuenta demo y usuarios recién
          // creados cuyo documento en Firestore se está creando en ese momento.
          allow read: if request.auth != null
            && resource.data.perfil.correo == request.auth.token.email;
          // Solo admin o propietario plataforma puede escribir el doc raíz
          allow write: if esAdminOPropietario(empresaId);
          // Cualquier auth puede crear una empresa (al registrarse)
          allow create: if isAuth();
          // Bootstrap: permite que admin/propietario escriba su empresa aunque
          // el doc de configuracion/modulos todavía no exista
          allow write: if isAuth()
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && getUserData().empresa_id == empresaId
            && (getUserData().rol == 'admin' || getUserData().rol == 'propietario');

          // CLIENTES — staff con módulo 'clientes'
          match /clientes/{clienteId} {
            allow read: if puedeVerModulo(empresaId, 'clientes');
            allow write: if esAdminOPropietario(empresaId);
          }

          // RESERVAS — staff con módulo 'reservas' o 'citas'
          match /reservas/{reservaId} {
            allow read: if puedeVerModulo(empresaId, 'reservas')
              || puedeVerModulo(empresaId, 'citas');
            allow write: if puedeVerModulo(empresaId, 'reservas')
              || puedeVerModulo(empresaId, 'citas');
            // Visitantes web pueden crear reservas sin autenticación
            allow create: if request.resource.data.estado == 'PENDIENTE';
          }

          // VALORACIONES — lectura pública; admin gestiona todo; staff responde si tiene módulo
          match /valoraciones/{valoracionId} {
            allow read: if true;
            allow create, update, delete: if esAdminOPropietario(empresaId) || esPlataformaAdmin();
            allow update: if staffTieneModulo(empresaId, 'valoraciones');
            // Visitantes web anónimos: validación anti-spam
            allow create: if request.resource.data.keys().hasAll(['cliente', 'calificacion'])
              && request.resource.data.calificacion is int
              && request.resource.data.calificacion >= 1
              && request.resource.data.calificacion <= 5
              && request.resource.data.size() <= 10;
          }

          // RESEÑAS — lectura pública; solo admin gestiona
          match /resenas/{resenaId} {
            allow read: if true;
            allow create, update, delete: if esAdminOPropietario(empresaId) || esPlataformaAdmin();
            allow create: if request.resource.data.keys().hasAll(['calificacion'])
              && request.resource.data.calificacion is int
              && request.resource.data.calificacion >= 1
              && request.resource.data.calificacion <= 5
              && request.resource.data.size() <= 15;
          }

          // PEDIDOS — staff con módulo 'pedidos'
          match /pedidos/{pedidoId} {
            allow read: if puedeVerModulo(empresaId, 'pedidos');
            allow create: if puedeVerModulo(empresaId, 'pedidos')
              && request.resource.data.keys().hasAll(['empresaId', 'timestamp'])
              && request.resource.data.empresaId == empresaId;
            allow update: if puedeVerModulo(empresaId, 'pedidos');
            allow delete: if esAdminOPropietario(empresaId);
          }

          // PEDIDOS WHATSAPP — staff con módulo 'pedidos' o 'whatsapp'
          match /pedidos_whatsapp/{pedidoId} {
            allow read: if puedeVerModulo(empresaId, 'pedidos')
              || puedeVerModulo(empresaId, 'whatsapp');
            allow create: if (puedeVerModulo(empresaId, 'pedidos') || puedeVerModulo(empresaId, 'whatsapp'))
              && request.resource.data.keys().hasAll(['empresaId', 'timestamp'])
              && request.resource.data.empresaId == empresaId;
            allow update, delete: if esAdminOPropietario(empresaId);
          }

          // PRODUCTOS — catálogo público para web
          match /productos/{productoId} {
            allow read: if true;
            allow write: if esAdminOPropietario(empresaId);
          }

          // SERVICIOS — solo admin gestiona; staff lo ve si tiene el módulo
          match /servicios/{servicioId} {
            allow read: if puedeVerModulo(empresaId, 'servicios');
            allow write: if esAdminOPropietario(empresaId);
          }

          // CUENTAS GOOGLE — admin del negocio o admin de plataforma
          match /cuentas_google/{cuentaId} {
            allow read, write: if esAdminOPropietario(empresaId) || esPlataformaAdmin();
          }

          // FACTURAS — solo admin
          match /facturas/{facturaId} {
            allow read, write: if esAdminOPropietario(empresaId) || esPlataformaAdmin();
          }

          // FACTURAS RECIBIDAS — solo admin
          match /facturas_recibidas/{facturaId} {
            allow read, write: if esAdminOPropietario(empresaId) || esPlataformaAdmin();
          }

          // FINIQUITOS — solo admin
          match /finiquitos/{finiquitoId} {
            allow read, write: if esAdminOPropietario(empresaId) || esPlataformaAdmin();
          }

          // TRANSACCIONES — solo admin
          match /transacciones/{transaccionId} {
            allow read, write: if esAdminOPropietario(empresaId) || esPlataformaAdmin();
          }

          // TAREAS — staff con módulo 'tareas'
          match /tareas/{tareaId} {
            allow read, write: if puedeVerModulo(empresaId, 'tareas');
            match /mensajes/{mensajeId} {
              allow read, write: if puedeVerModulo(empresaId, 'tareas');
            }
          }

          // NÓMINAS — staff solo ve las suyas (RGPD); admin ve todas
          match /nominas/{nominaId} {
            allow read: if esAdminOPropietario(empresaId)
              || (perteneceAEmpresa(empresaId) && resource.data.empleado_id == request.auth.uid);
            allow write: if esAdminOPropietario(empresaId);
          }

          // EQUIPOS
          match /equipos/{equipoId} {
            allow read: if esStaffOSuperior(empresaId);
            allow write: if esAdminOPropietario(empresaId);
          }

          // SECCIONES WEB — lectura pública para WordPress
          match /secciones_web/{seccionId} {
            allow read: if true;
            allow write: if esAdminOPropietario(empresaId);
          }

          // CONTENIDO WEB — lectura pública, escritura con auth
          match /contenido_web/{docId} {
            allow read: if true;
            allow write: if request.auth != null;
          }

          // CONTACTO WEB — formulario de contacto desde la web (sin auth)
          match /contacto_web/{mensajeId} {
            allow create: if request.resource.data.keys().hasAll(['nombre', 'email', 'mensaje'])
              && request.resource.data.nombre is string
              && request.resource.data.nombre.size() > 0
              && request.resource.data.email is string
              && request.resource.data.email.size() > 0
              && request.resource.data.mensaje is string
              && request.resource.data.mensaje.size() > 0
              && request.resource.data.mensaje.size() <= 2000;
            allow read, update, delete: if esAdminOPropietario(empresaId);
          }

          // DISPOSITIVOS FCM — cada usuario escribe su propio token
          match /dispositivos/{dispositivoId} {
            allow read: if esAdminOPropietario(empresaId);
            allow write: if isAuth();
          }

          // SUSCRIPCIÓN — solo lectura para miembros
          match /suscripcion/{docId} {
            allow read: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
            allow write: if false; // Solo Admin SDK
          }

          // ESTADÍSTICAS — lectura para miembros, escritura protegida
          match /estadisticas/{docId} {
            allow read: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
            allow write: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
          }
          match /estadisticas/{docId}/{subcol}/{subId} {
            allow read: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
            allow write: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
          }

          // ANALYTICS WEB — escritura pública para el script JS (sin auth)
          // Solo permite actualizar el documento 'trafico_web' con merge
          // Los visitantes de la web ESCRIBEN aquí, la app Flutter LEE
          // Seguridad: solo set/update, no delete. Lectura solo autenticados.
          match /estadisticas/trafico_web {
            allow read: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
            allow create, update: if true;
            allow delete: if perteneceAEmpresa(empresaId);
          }
          match /estadisticas/trafico_web/historico_diario/{fecha} {
            allow read: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
            allow create, update: if true;
            allow delete: if perteneceAEmpresa(empresaId);
          }

          // EVENTOS WEB — escritura pública (analíticas de clicks)
          // Solo create (no update/delete), lectura restringida
          match /eventos_web/{eventoId} {
            allow read: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
            allow create: if true
              && request.resource.data.keys().hasAll(['tipo', 'fecha_iso'])
              && request.resource.data.tipo is string
              && request.resource.data.tipo.size() <= 50;
            allow update, delete: if esAdminOPropietario(empresaId);
          }

          // CACHÉ (estadísticas calculadas)
          match /cache/{docId} {
            allow read, write: if perteneceAEmpresa(empresaId);
          }

          // CONFIGURACIÓN (módulos, widgets, ajustes)
          match /configuracion/{docId} {
            allow read: if perteneceAEmpresa(empresaId) || esPlataformaAdmin();
            // El script web necesita leer web_avanzada (popup, banner, contacto)
            allow read: if request.auth != null && docId == 'web_avanzada';
            // El script web puede CREAR web_avanzada si no existe (primera carga)
            allow create: if request.auth != null && docId == 'web_avanzada';
            // Admin del negocio O admin de plataforma pueden gestionar configuración
            // (gmb_config, google_reviews, módulos, etc.)
            allow create, update, delete: if esAdminOPropietario(empresaId) || esPlataformaAdmin();
          }

          // CIERRES DE CAJA
          match /cierres_caja/{cierreId} {
            // Cualquier miembro puede leer el historial
            allow read: if perteneceAEmpresa(empresaId);
            // Solo admin/propietario puede crear (cerrar caja) — no se permite editar ni borrar
            allow create: if esAdminOPropietario(empresaId);
            allow update, delete: if false;
          }

        } // ── FIN match /empresas/{empresaId} ─────────────────────────────────

        // ── CONVENIOS (colección raíz) ─────────────────────────────────────────
        match /convenios/{convenioId} {
          allow read: if isAuth();
          allow create, update: if isAuth()
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && getUserData().rol == 'propietario';
          allow delete: if false;

          match /{subcollection}/{docId} {
            allow read: if isAuth();
            allow create, update: if isAuth()
              && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
              && getUserData().rol == 'propietario';
            allow delete: if false;
          }
        }

        // ── PAGOS DE PLATAFORMA ─────────────────────────────────────────────────
        match /plataforma_pagos/{pagoId} {
          allow read: if isAuth()
            && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && getUserData().es_plataforma_admin == true;
          allow write: if false; // Solo Admin SDK
        }

        // ── REGLA POR DEFECTO: denegar todo lo demás ──────────────────────────────
        match /{document=**} {
          allow read, write: if false;
        }

      } // match /databases/{database}/documents
    } // service cloud.firestore
